# Supabase Postgres connection.
# Use the *pooled* connection string for DATABASE_URL (port 6543, ?pgbouncer=true)
# and the *direct* connection (port 5432) for DIRECT_URL — Prisma needs it for
# migrations because pgbouncer in transaction mode breaks prepared statements.
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Cloudflare R2 (S3-compatible).
R2_ACCOUNT_ID="<cloudflare account id>"
R2_ACCESS_KEY_ID="<r2 token access key>"
R2_SECRET_ACCESS_KEY="<r2 token secret>"
R2_BUCKET="wareongo-panos"

# Public base URL for served R2 objects. Either the bucket's r2.dev URL or a
# custom domain bound to the bucket. Trailing slash optional.
R2_PUBLIC_URL="https://pub-<hash>.r2.dev"

# ─── Auth (NextAuth / Auth.js v5) ─────────────────────────────────────────────
# AUTH_SECRET signs the session JWT. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET="<32+ random chars>"

# Google OAuth client. Create at:
#   Google Cloud Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Set the application type to "Web application" and add these as
# "Authorized redirect URIs":
#   http://localhost:3000/api/auth/callback/google
#   https://your.domain/api/auth/callback/google
# Sign-in is gated to @wareongo.com via src/auth.js — Google still authenticates
# any account, but the signIn callback rejects non-Wareongo emails.
AUTH_GOOGLE_ID="<client id>.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="<client secret>"



# Set when behind a proxy/CDN (Vercel sets this automatically; bare-metal
# deploys need it). Safe to leave unset in local dev.
# AUTH_TRUST_HOST=true

# ─── ElevenLabs (admin TTS for scene narration) ───────────────────────────────
# API key from elevenlabs.io → Profile → API Keys. Server-side only.
# Without this, the "Generate (TTS)" tab on the audio upload field is disabled.
ELEVENLABS_API_KEY="<sk_... or xi_... key>"

# ─── R2 bucket CORS ───────────────────────────────────────────────────────────
# Direct browser uploads via presigned PUT require the bucket to allow PUT from
# the admin origin. In the Cloudflare dashboard → R2 → bucket → Settings → CORS
# Policy, set something like:
#
#   [
#     {
#       "AllowedOrigins": ["http://localhost:3000", "https://your.domain"],
#       "AllowedMethods": ["PUT"],
#       "AllowedHeaders": ["Content-Type"],
#       "MaxAgeSeconds": 3600
#     }
#   ]
